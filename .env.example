# =============================================================================
# תבנית משתני סביבה — העתק ל-.env.development / .env.production
# פורמט: KEY=value (בלי רווחים לפני/אחרי =)
# לא לשמור ערכים אמיתיים ב-Git; ב-Vercel הגדר Environment Variables
# =============================================================================

# --- חובה לריצה תקינה ---
# מצב ריצה: development | production
NODE_ENV=development

# פורט HTTP
PORT=8181

# סוג מסד בקוד (MONGODB = Mongoose)
DB=MONGODB

# חתימת JWT — מפתח ארוך ואקראי (בפרודקשן חובה). אפשר JWT_KEY או JWT_SECRET
JWT_KEY=your_jwt_secret_min_32_chars_recommended
# JWT_SECRET=your_jwt_secret_min_32_chars_recommended

# --- MongoDB (בחר שיטה אחת) ---
# מומלץ לפרודקשן / Vercel: מחרוזת חיבור מלאה
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/

# חלופה: הרכבה מחלקים (אם אין MONGODB_URI)
DB_NAME=your_atlas_username
DB_PASSWORD=your_atlas_password
MONGODB_CLUSTER_HOST=cluster0.xxxxx.mongodb.net

# --- אופציונלי (ברירות מחדל ב-config אם חסר) ---
# מנוע טוקן (ברירת מחדל: jwt)
TOKEN_GENERATOR=jwt

# לוג HTTP: morgan | אחר (לפי loggerService)
LOGGER=morgan

# --- סקריפטים ב-DB/ בלבד (חיבור לוקאלי לכלי עזר) ---
# אם לא מוגדר — ברירת מחדל mongodb://localhost:27017/business_card_app
# MONGODB_URI=mongodb://localhost:27017/business_card_app

# --- Legacy (לא מומלץ — רק תאימות לאחור) ---
# MONGO_URI — שם ישן; העדף MONGODB_URI
