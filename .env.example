# העתק לקובץ .env.development או .env.production (לא לשמור סודות ב-Git).
# פורמט: KEY=value (בלי רווחים סביב =)

NODE_ENV=development
PORT=8181
DB=MONGODB

# JWT — מפתח ארוך ואקראי (לפחות 32 תווים מומלץ)
JWT_KEY=replace_with_a_long_random_secret

# MongoDB Atlas — אחת מהאפשרויות:
# א) מחרוזת חיבור מלאה (מומלץ לפרודקשן / Vercel)
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/

# ב) שלושה ערכים נפרדים (מתאים ל-custom-environment-variables)
DB_NAME=your_atlas_username
DB_PASSWORD=your_atlas_password
MONGODB_CLUSTER_HOST=your-cluster.xxxxx.mongodb.net

TOKEN_GENERATOR=jwt
LOGGER=morgan

# סקריפטים ב-DB/ (אופציונלי): חיבור לוקאלי או Atlas
# MONGO_URI=mongodb://localhost:27017/business_card_app
